<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Santa Ajuda Cerimonial – Assessoria de Eventos | Franca, SP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    /* ── Variables ── */
    :root {
      --wine:   #6B0F1A;
      --wine-d: #4A0A12;
      --wine-l: #8B1A27;
      --rose:   #E8B4A8;
      --rose-l: #F0CCBF;
      --rose-d: #C8907E;
      --cream:  #FAF5F0;
      --text:   #2E1015;
      --muted:  #7A5560;
      --white:  #FFFFFF;
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Jost', sans-serif;
      background: var(--cream);
      color: var(--text);
      overflow-x: hidden;
    }
    img { display: block; width: 100%; }
    a { text-decoration: none; color: inherit; }

    /* ── Utility ── */
    .section-label {
      font-family: 'Jost', sans-serif;
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--rose-d);
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-weight: 400;
      line-height: 1.15;
      color: var(--wine);
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.9rem 2rem;
      border-radius: 0;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .btn-wine {
      background: var(--wine);
      color: var(--rose-l);
      border: 1px solid var(--wine);
    }
    .btn-wine:hover {
      background: var(--wine-d);
      border-color: var(--wine-d);
    }
    .btn-outline {
      background: transparent;
      color: var(--wine);
      border: 1px solid var(--rose-d);
    }
    .btn-outline:hover {
      background: var(--wine);
      color: var(--rose-l);
      border-color: var(--wine);
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.2rem 4vw;
      transition: background 0.4s, box-shadow 0.4s;
    }
    nav.scrolled {
      background: rgba(106, 15, 26, 0.97);
      backdrop-filter: blur(8px);
      box-shadow: 0 2px 24px rgba(0,0,0,0.18);
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--rose-l);
      letter-spacing: 0.06em;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rose);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-cta {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.6rem 1.4rem;
      border: 1px solid var(--rose);
      color: var(--rose);
      transition: all 0.2s;
    }
    .nav-cta:hover {
      background: var(--rose);
      color: var(--wine-d);
    }
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 4px;
    }
    .nav-hamburger span {
      display: block;
      width: 22px;
      height: 1.5px;
      background: var(--rose-l);
      transition: all 0.3s;
    }
    .mobile-menu {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: var(--wine-d);
      z-index: 200;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      color: var(--rose-l);
      letter-spacing: 0.05em;
    }
    .mobile-close {
      position: absolute;
      top: 1.5rem; right: 4vw;
      font-size: 1.8rem;
      color: var(--rose);
      cursor: pointer;
      background: none;
      border: none;
    }

    /* ── HERO ── */
    #hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: var(--wine-d);
    }
    .hero-img-desktop,
    .hero-img-mobile {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center;
      /* Imagem de noivos real para o Hero */
      background-image: url('https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&w=1600&q=80');
      opacity: 0.6;
      transition: opacity 0.6s;
    }
    .hero-img-mobile {
      display: none;
      background-image: url('https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=800&q=80');
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(74,10,18,0.92) 0%, rgba(74,10,18,0.35) 60%, transparent 100%);
    }
    .hero-content {
      position: relative;
      z-index: 2;
      padding: 0 4vw 6vh;
      max-width: 760px;
    }
    .hero-eyebrow {
      font-size: 0.65rem;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 1rem;
    }
    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      font-weight: 300;
      color: var(--white);
      line-height: 1.08;
      margin-bottom: 1.25rem;
    }
    .hero-title em {
      font-style: italic;
      color: var(--rose-l);
    }
    .hero-sub {
      font-size: 0.85rem;
      color: var(--rose);
      letter-spacing: 0.08em;
      margin-bottom: 2rem;
      max-width: 440px;
      line-height: 1.7;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

    /* ── SOBRE ── */
    #sobre {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
    .sobre-img-wrap {
      position: relative;
      overflow: hidden;
    }
    .sobre-img-desktop {
      width: 100%;
      height: 100%;
      object-fit: cover;
      /* Foto de cerimonialista/detalhe elegante */
      background: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=800&q=80') center/cover no-repeat;
      min-height: 400px;
    }
    .sobre-img-mobile { display: none; }

    .sobre-text {
      padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      background: var(--cream);
    }
    .sobre-text .section-title { font-size: clamp(2rem, 3.5vw, 3rem); margin-bottom: 1.25rem; }
    .sobre-text p {
      font-size: 0.9rem;
      line-height: 1.85;
      color: var(--muted);
      margin-bottom: 1rem;
    }
    .sobre-stat-row {
      display: flex;
      gap: 2rem;
      margin-top: 1.5rem;
      flex-wrap: wrap;
    }
    .sobre-stat { text-align: center; }
    .sobre-stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 300;
      color: var(--wine);
      line-height: 1;
    }
    .sobre-stat-label {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose-d);
      margin-top: 0.3rem;
    }

    /* ── SERVIÇOS ── */
    #servicos {
      background: var(--wine);
      padding: clamp(3rem, 7vw, 7rem) 4vw;
      text-align: center;
    }
    #servicos .section-label { color: var(--rose); }
    #servicos .section-title { color: var(--rose-l); font-size: clamp(2rem, 3.5vw, 3rem); margin-bottom: 3rem; }
    .servicos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1.5px;
      max-width: 1100px;
      margin: 0 auto;
    }
    .servico-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(232,180,168,0.15);
      padding: 2.5rem 2rem;
      text-align: left;
      transition: background 0.3s;
    }
    .servico-card:hover { background: rgba(232,180,168,0.08); }
    .servico-icon {
      font-size: 1.6rem;
      margin-bottom: 1rem;
      display: block;
    }
    .servico-card h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-weight: 400;
      color: var(--rose-l);
      margin-bottom: 0.6rem;
    }
    .servico-card p {
      font-size: 0.8rem;
      line-height: 1.75;
      color: var(--rose);
      opacity: 0.8;
    }


    /* ── PORTFOLIO ── */
    #portfolio {
      padding: clamp(3rem, 7vw, 7rem) 4vw;
      background: var(--cream);
    }
    #portfolio .section-label { text-align: center; }
    #portfolio .section-title { text-align: center; font-size: clamp(2rem, 3.5vw, 3rem); margin-bottom: 3rem; }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto;
      gap: 12px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .portfolio-item {
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }
    .portfolio-item::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(74,10,18,0.7) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.35s;
    }
    .portfolio-item:hover::after { opacity: 1; }
    .portfolio-item:hover .portfolio-caption { opacity: 1; transform: translateY(0); }

    /* Imagens de portfólio reais */
    /* pi1: Noivos no altar */
.pi1 {
  grid-column: 1 / 8;
  grid-row: 1;
  background: url('https://cdn0.casamentos.com.br/article/5721/3_2/960/jpg/61275-diseo-sin-ttulo-2023-08-02t094639-648.jpeg') center/cover no-repeat;
  min-height: 360px;
}

/* pi2: Noivos sorrindo (Campinas) */
.pi2 {
  grid-column: 8 / 13;
  grid-row: 1;
  background: url('https://storage.alboom.ninja/sites/1132/albuns/432635/fotos-casamento-casal-noivos-regiane-e-fabio-campinas-espaco-quinta-das-brumelias-campinas-sp-fotografo-denis-silveira-fotografia-wedding-photography-182.JPG?t=1656367338') center/cover no-repeat;
}

/* pi3: Noiva detalhe (Pinterest) */
.pi3 {
  grid-column: 1 / 5;
  grid-row: 2;
  background: url('https://i.pinimg.com/474x/68/62/33/68623395090b183d8dbb96091a7ab403.jpg') center/cover no-repeat;
  min-height: 300px;
}

/* pi4: Noivos abraçados (Unsplash) */
.pi4 {
  grid-column: 5 / 9;
  grid-row: 2;
  background: url('https://plus.unsplash.com/premium_photo-1661386198461-c57783b28c2f?fm=jpg&q=60&w=1000&auto=format&fit=crop') center/cover no-repeat;
}

/* pi5: Noivos com flores (Porto Seguro) */
.pi5 {
  grid-column: 9 / 13;
  grid-row: 2;
  background: url('https://blog.portoseguro.com.br/wordpress/wp-content/uploads/2024/06/Casal-de-noivos-sorrindo-rodeado-de-flores-em-uma-cerimonia-de-casamento-scaled.jpg') center/cover no-repeat;
}

  @media (max-width: 900px) {
  /* Deixe apenas as regras de layout. 
     As imagens serão herdadas automaticamente do código acima. */
  .portfolio-grid { 
    grid-template-columns: 1fr 1fr; 
  }
  .pi1 { grid-column: 1 / 3; grid-row: 1; min-height: 240px; }
  .pi2 { grid-column: 1 / 2; grid-row: 2; min-height: 200px; }
  .pi3 { grid-column: 2 / 3; grid-row: 2; min-height: 200px; }
  .pi4 { grid-column: 1 / 2; grid-row: 3; min-height: 200px; }
  .pi5 { grid-column: 2 / 3; grid-row: 3; min-height: 200px; }
}


    .portfolio-caption {
      position: absolute;
      bottom: 1.2rem; left: 1.2rem;
      z-index: 2;
      opacity: 0;
      transform: translateY(8px);
      transition: all 0.35s;
    }
    .portfolio-caption h4 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      color: var(--white);
      font-weight: 400;
    }
    .portfolio-caption span {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose);
    }

    /* ── DEPOIMENTOS ── */
    #depoimentos {
      background: var(--wine-d);
      padding: clamp(3rem, 7vw, 7rem) 4vw;
      overflow: hidden;
    }
    #depoimentos .section-label { text-align: center; color: var(--rose); }
    #depoimentos .section-title { text-align: center; color: var(--rose-l); font-size: clamp(2rem, 3.5vw, 3rem); margin-bottom: 3rem; }
    .dep-slider {
      max-width: 860px;
      margin: 0 auto;
      position: relative;
    }
    .dep-track {
      overflow: hidden;
    }
    .dep-cards {
      display: flex;
      transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
    }
    .dep-card {
      min-width: 100%;
      padding: 3rem;
      border: 1px solid rgba(232,180,168,0.15);
      background: rgba(255,255,255,0.04);
      text-align: center;
    }
    .dep-stars { color: var(--rose); font-size: 1rem; letter-spacing: 0.2em; margin-bottom: 1.5rem; }
    .dep-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.2rem, 2vw, 1.65rem);
      font-style: italic;
      font-weight: 300;
      color: var(--rose-l);
      line-height: 1.55;
      margin-bottom: 1.5rem;
    }
    .dep-name {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rose);
    }
    .dep-controls {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1rem;
      margin-top: 2rem;
    }
    .dep-btn {
      width: 38px; height: 38px;
      border: 1px solid rgba(232,180,168,0.3);
      background: transparent;
      color: var(--rose);
      font-size: 1rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .dep-btn:hover { background: var(--rose); color: var(--wine-d); }
    .dep-dots { display: flex; gap: 6px; }
    .dep-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: rgba(232,180,168,0.3);
      cursor: pointer;
      transition: background 0.2s;
    }
    .dep-dot.active { background: var(--rose); }

    /* ── PROCESSO ── */
    #processo {
      padding: clamp(3rem, 7vw, 7rem) 4vw;
      background: var(--cream);
    }
    #processo .section-label { text-align: center; }
    #processo .section-title { text-align: center; font-size: clamp(2rem, 3.5vw, 3rem); margin-bottom: 3rem; }
    .processo-steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0;
      max-width: 1000px;
      margin: 0 auto;
    }
    .passo {
      padding: 2.5rem 2rem;
      border-top: 1px solid var(--rose-d);
      position: relative;
    }
    .passo-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3.5rem;
      font-weight: 300;
      color: rgba(139,26,39,0.12);
      line-height: 1;
      margin-bottom: 0.75rem;
    }
    .passo h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      color: var(--wine);
      font-weight: 400;
      margin-bottom: 0.5rem;
    }
    .passo p {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.75;
    }

    /* ── GALERIA BANNER (strip) ── */
    .galeria-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      height: 28vw;
      max-height: 320px;
      overflow: hidden;
    }
    .gs-item {
      overflow: hidden;
      position: relative;
    }
    .gs-item:nth-child(1) { background: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=500&q=80') center/cover no-repeat; }
    .gs-item:nth-child(2) { background: url('https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=500&q=80') center/cover no-repeat; }
    .gs-item:nth-child(3) { background: url('https://images.unsplash.com/photo-1510076857177-7470076d4098?auto=format&fit=crop&w=500&q=80') center/cover no-repeat; }
    .gs-item:nth-child(4) { background: url('https://images.unsplash.com/photo-1511795409834-ef04bbd61622?auto=format&fit=crop&w=500&q=80') center/cover no-repeat; }
    .gs-item::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(74,10,18,0.3);
      transition: opacity 0.3s;
    }
    .gs-item:hover::after { opacity: 0; }

    /* ── CONTATO ── */
    #contato {
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 70vh;
    }
    .contato-img-wrap {
      position: relative;
      overflow: hidden;
    }
    .contato-img-desktop {
      width: 100%;
      height: 100%;
      min-height: 400px;
      background: url('https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=800&q=80') center/cover no-repeat;
    }
    .contato-img-mobile { display: none; }
    .contato-form-area {
      background: var(--wine);
      padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .contato-form-area .section-label { color: var(--rose); }
    .contato-form-area .section-title { color: var(--rose-l); font-size: clamp(1.8rem, 2.8vw, 2.5rem); margin-bottom: 0.5rem; }
    .contato-sub {
      font-size: 0.82rem;
      color: var(--rose);
      opacity: 0.75;
      margin-bottom: 2rem;
      line-height: 1.7;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
    .form-group label {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose);
      opacity: 0.8;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(232,180,168,0.25);
      color: var(--rose-l);
      padding: 0.85rem 1rem;
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
      resize: none;
    }
    .form-group input::placeholder,
    .form-group textarea::placeholder { color: rgba(232,180,168,0.4); }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus { border-color: var(--rose); }
    .form-group select option { background: var(--wine-d); color: var(--rose-l); }
    .form-submit { width: 100%; justify-content: center; margin-top: 0.5rem; }

    /* ── FOOTER ── */
    footer {
      background: var(--wine-d);
      padding: 3rem 4vw 2rem;
      border-top: 1px solid rgba(232,180,168,0.1);
    }
    .footer-inner {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 3rem;
      max-width: 1100px;
      margin: 0 auto 2.5rem;
    }
    .footer-brand .brand-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      color: var(--rose-l);
      margin-bottom: 0.3rem;
    }
    .footer-brand .brand-sub {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rose);
      opacity: 0.7;
      margin-bottom: 1rem;
    }
    .footer-brand p {
      font-size: 0.8rem;
      color: var(--rose);
      opacity: 0.65;
      line-height: 1.7;
    }
    .footer-col h4 {
      font-size: 0.65rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rose-d);
      margin-bottom: 1rem;
    }

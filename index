<script>
  /* NAV scroll */
  const nav = document.getElementById('mainNav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });

  /* Mobile menu */
  function openMobileMenu() { document.getElementById('mobileMenu').classList.add('open'); document.body.style.overflow = 'hidden'; }
  function closeMobileMenu() { document.getElementById('mobileMenu').classList.remove('open'); document.body.style.overflow = ''; }

  /* Depoimentos slider */
  let depIdx = 0;
  const depCards = document.getElementById('depCards');
  const depDotsEl = document.getElementById('depDots');
  const totalDep = depCards.children.length;

  for (let i = 0; i < totalDep; i++) {
    const d = document.createElement('div');
    d.className = 'dep-dot' + (i === 0 ? ' active' : '');
    d.onclick = () => goDepoimento(i);
    depDotsEl.appendChild(d);
  }

  function goDepoimento(n) {
    depIdx = (n + totalDep) % totalDep;
    depCards.style.transform = `translateX(-${depIdx * 100}%)`;
    document.querySelectorAll('.dep-dot').forEach((d, i) => d.classList.toggle('active', i === depIdx));
  }
  function slideDepoimento(dir) { goDepoimento(depIdx + dir); }

  setInterval(() => slideDepoimento(1), 5000);

  /* Fade-up on scroll */
  const fadeEls = document.querySelectorAll('.fade-up');
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
  }, { threshold: 0.12 });
  fadeEls.forEach(el => io.observe(el));

  /* WhatsApp form sender */
  function enviarWhatsApp() {
    const nome = document.getElementById('f-nome').value.trim();
    const parceiro = document.getElementById('f-parceiro').value.trim();
    const tel = document.getElementById('f-tel').value.trim();
    const data = document.getElementById('f-data').value.trim();
    const servico = document.getElementById('f-servico').value;
    const msg = document.getElementById('f-msg').value.trim();

    if (!nome) { alert('Por favor, informe seu nome.'); return; }

    let texto = `Olá! Sou ${nome}`;
    if (parceiro) texto += ` e ${parceiro}`;
    texto += `. Estamos interessados na assessoria da Santa Ajuda Cerimonial!`;
    if (servico) texto += `\n\n*Serviço:* ${servico}`;
    if (data) texto += `\n*Data prevista:* ${data}`;
    if (tel) texto += `\n*Contato:* ${tel}`;
    if (msg) texto += `\n\n*Mensagem:* ${msg}`;

    const url = `https://wa.me/5516991356880?text=${encodeURIComponent(texto)}`;
    window.open(url, '_blank');
  }
</script>
